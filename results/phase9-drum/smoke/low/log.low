AUDIT settle: step 100000  atoms = 4600 (target 4600)  KE = 2.89845900476994e-10 J

# stage 2 — rotate the shell about y at 5 rpm; discard the spin-up transient.
# Sign convention: positive period -> angular velocity +y; the bed climbs the
