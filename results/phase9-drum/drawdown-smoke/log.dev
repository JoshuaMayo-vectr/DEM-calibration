# stage 2 — open the orifice: slide the plug down at 0.5 m/s for 0.09 s
# (parks at z ~ -0.044, below the counting plane), then discharge
fix	mvplug all move/mesh mesh plug linear 0. 0. -0.5
run	${opensteps}
run	11250
