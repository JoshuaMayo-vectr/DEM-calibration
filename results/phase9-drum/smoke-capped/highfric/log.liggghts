# drum shell: generated STL imported as a mesh wall (type 2), rotated in stage 2
fix drum all mesh/surface file ${MESH} type 2
fix drum all mesh/surface file ../../../../templates/meshes/drum_r0.075_l0.025_capped.stl type 2
fix drumwall all wall/gran model hertz tangential history rolling_friction epsd2 mesh n_meshes 1 meshes drum
