pair_coeff	* *

timestep	${DT}
timestep	8.0e-6

fix		gravi all gravity 9.81 vector 0.0 ${gy} ${gz}
fix		gravi all gravity 9.81 vector 0.0 -0.707106781186547 ${gz}
fix		gravi all gravity 9.81 vector 0.0 -0.707106781186547 -0.707106781186548

# containment backstop: frictionless-in-effect primitive y-planes parked
# outside the cover disks (type 3 pair would apply, but they are unreachable)
fix ycap1 all wall/gran model hertz tangential history rolling_friction epsd2 primitive type 3 yplane -${CAPY}
fix ycap1 all wall/gran model hertz tangential history rolling_friction epsd2 primitive type 3 yplane -0.026
