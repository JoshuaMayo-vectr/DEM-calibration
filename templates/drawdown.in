# drawdown.in — Parameterized orifice-discharge (drawdown) flow test (Phase-9 probe).
#
# Fill the lifted-cylinder geometry over an annular floor whose orifice is
# blocked by a plug disk; settle; remove the plug; discharge through the
# orifice. Mass flow rate comes from fix massflow/mesh on a counting disk
# below the floor (delete_atoms keeps the shrink-wrapped domain bounded —
# the Phase-5 neighbor-grid lesson). The probe question is DISCRIMINATION
# along the Phase-8 friction valley, so no physical target is required yet.
#
# Inertial orifice flow is a genuinely different regime from the quasi-static
# heap and the slow-rolling drum — the two responses that proved degenerate
# for single spheres (results/phase9-drum/NOTES.md, M4).
#
# Run (from repo root):
#   mpirun -np 2 lmp_auto -in templates/drawdown.in \
#       -var TAG dev -var FRIC 0.4 -var ROLLFRIC 0.12 -var REST 0.5 -log log.dev
#
# Atom types: 1 = particles, 2 = walls (cylinder + floor + plug; matrix as aor.in).

# ---------------------------------------------------------------- variables
variable FRIC       index 0.40          # mu_s particle-particle  [calibration target]
variable FRICPW     index 0.40          # mu_s particle-wall      [calibration target]
variable ROLLFRIC   index 0.12          # mu_r particle-particle, epsd2 [target]
variable ROLLFRICPW index 0.12          # mu_r particle-wall, epsd2     [target]
variable REST       index 0.50          # restitution             [target, weak]
variable SEED       index 49979687      # insertion seed
variable TAG        index dev           # output label
variable NPART      index 4000          # particles inserted (the aor fill)
variable MESH       index templates/meshes/cylinder_r0.040_h0.100.stl
variable FLOORMESH  index templates/meshes/floor_annulus_r0.046_o0.011.stl
variable PLUGMESH   index templates/meshes/plug_disk_r0.0135.stl
variable CATCHMESH  index templates/meshes/catch_disk_r0.030.stl
variable YMOD       index 1.0e7         # softened Young's modulus [Pa]
variable DT         index 8.0e-6        # timestep [s]
variable GRAVZ      index -1.0          # gravity z sign (fault-injection knob)
variable SETTLET    index 0.4           # settle stage [s]
variable DISCHARGE  index 1.4           # discharge stage [s] (~full drain at D_o 22 mm)

# fixed (non-calibrated) material inputs
variable POIS       equal 0.25
variable RHO        equal 1400

variable settlesteps equal floor(v_SETTLET/v_DT+0.5)
variable opensteps   equal floor(0.09/v_DT+0.5)
variable dischsteps  equal floor(v_DISCHARGE/v_DT+0.5)-floor(0.09/v_DT+0.5)
variable dumpevery   equal 25000

# ---------------------------------------------------------------- setup
atom_style	granular
atom_modify	map array
boundary	m m m
newton		off
communicate	single vel yes
units		si

region		reg block -0.14 0.14 -0.14 0.14 -0.05 0.20 units box
create_box	2 reg

neighbor	0.002 bin
neigh_modify	delay 0

# ---------------------------------------------------------------- material / contact model
fix 	m1 all property/global youngsModulus peratomtype ${YMOD} ${YMOD}
fix 	m2 all property/global poissonsRatio peratomtype ${POIS} ${POIS}
fix 	m3 all property/global coefficientRestitution peratomtypepair 2 ${REST} ${REST} ${REST} ${REST}
fix 	m4 all property/global coefficientFriction peratomtypepair 2 ${FRIC} ${FRICPW} ${FRICPW} ${FRICPW}
fix 	m5 all property/global coefficientRollingFriction peratomtypepair 2 ${ROLLFRIC} ${ROLLFRICPW} ${ROLLFRICPW} ${ROLLFRICPW}

pair_style gran model hertz tangential history rolling_friction epsd2
pair_coeff	* *

timestep	${DT}

fix		gravi all gravity 9.81 vector 0.0 0.0 ${GRAVZ}

# cylinder side wall + annular floor + plug: ONE wall fix — LIGGGHTS 3.8
# supports a single wall/gran of style mesh, so the plug cannot get its own
# (first smoke run failed on exactly that). The orifice opens by MOVING the
# plug down out of the flow (fix move/mesh, the aor.in lift pattern) and
# parking it below the counting plane.
fix cyl   all mesh/surface file ${MESH} type 2
fix floor all mesh/surface file ${FLOORMESH} type 2
fix plug  all mesh/surface file ${PLUGMESH} type 2
fix statwall all wall/gran model hertz tangential history rolling_friction epsd2 mesh n_meshes 3 meshes cyl floor plug

# counting plane below the orifice — NOT a wall; massflow counts + deletes
fix catch all mesh/surface file ${CATCHMESH} type 2
fix ms all massflow/mesh mesh catch vec_side 0. 0. -1. count once delete_atoms yes

# ---------------------------------------------------------------- particles (fixed PSD)
fix	pts1 all particletemplate/sphere 15485863 atom_type 1 density constant ${RHO} radius constant 0.0017
fix	pts2 all particletemplate/sphere 15485867 atom_type 1 density constant ${RHO} radius constant 0.00185
fix	pts3 all particletemplate/sphere 32452843 atom_type 1 density constant ${RHO} radius constant 0.0020
fix	pdd1 all particledistribution/discrete 32452867 3 pts1 0.25 pts2 0.50 pts3 0.25

region	bc cylinder z 0. 0. 0.0375 0.004 0.085 units box
fix	ins all insert/pack seed ${SEED} distributiontemplate pdd1 vel constant 0. 0. -0.3 &
		insert_every once overlapcheck yes all_in yes particles_in_region ${NPART} region bc

fix	integr all nve/sphere

# nevery 1000 to match the fine thermo cadence (thermo errors out when a
# referenced fix computes on an incompatible schedule)
fix	ts all check/timestep/gran 1000 0.1 0.1

# ---------------------------------------------------------------- output
# fine-grained thermo (8 ms) is the measurement: f_ms[1] = crossed mass [kg]
compute	rke all erotate/sphere
thermo_style	custom step atoms ke f_ms[1] f_ts[1] f_ts[2]
thermo		1000
thermo_modify	lost ignore norm no
dump	dmp all custom ${dumpevery} post/${TAG}_*.liggghts id type x y z vx vy vz omegax omegay omegaz radius

# ---------------------------------------------------------------- stages
# stage 1 — fill and settle over the plugged orifice
run	${settlesteps}
variable natoms equal atoms
print	"AUDIT settle: atoms = ${natoms} (target ${NPART})"

# stage 2 — open the orifice: slide the plug down at 0.5 m/s for 0.09 s
# (parks at z ~ -0.044, below the counting plane), then discharge
fix	mvplug all move/mesh mesh plug linear 0. 0. -0.5
run	${opensteps}
unfix	mvplug
run	${dischsteps}
variable mout equal f_ms[1]
print	"AUDIT discharge-end: crossed mass = ${mout} kg, atoms left = ${natoms}"

write_dump all custom post/${TAG}_final.liggghts id type x y z vx vy vz omegax omegay omegaz radius
