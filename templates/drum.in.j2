# drum.in — Parameterized rotating-drum dynamic angle-of-repose test (Phase 9).
#
# Fill a y-axis drum shell to 50% of its volume with wheat-scale spheres,
# settle, spin the shell about y via fix move/mesh rotate, discard the spin-up
# transient, dump the steady-state window for multi-frame surface fitting.
#
# Protocol: Sugirbay et al. 2022 (vertical drum, 5 rpm, 50% fill, rolling
# regime, co-rotating acrylic covers) — see experiments/ground-truth-wheat-
# literature.md, "Rotating drum" section, incl. the documented deviation
# (axial length halved). Target: dynamic AoR 36.17 deg +/- 3.1 deg.
#
# Run (from repo root):
#   mpirun -np 2 lmp_auto -in templates/drum.in \
#       -var TAG dev -var FRIC 0.4 -var ROLLFRIC 0.12 -var REST 0.5 -log log.dev
#
# Atom types: 1 = particles, 2 = drum shell (rotating mesh, frictional at
# FRICPW), 3 = end covers (CO-ROTATING cap-disk mesh, frictional at CAPFRIC —
# the published protocol's acrylic cover rotates with the drum; wheat-acrylic
# friction from Sugirbay Table 11). Static frictional caps are UNPHYSICAL:
# they grip the thin bed while the shell slides underneath (M4 side check:
# angle collapsed to ~1-2 deg). Frictionless primitive y-planes remain parked
# just OUTSIDE the cover disks (CAPY) as a containment backstop only.
# property/global peratomtypepair 3 takes the symmetric 3x3 matrix in row order
# (1,1) (1,2) (1,3) (2,1) (2,2) (2,3) (3,1) (3,2) (3,3); wall-wall entries are
# never exercised.

# ---------------------------------------------------------------- variables
variable FRIC       index 0.40          # mu_s particle-particle  [calibration target]
variable FRICPW     index 0.40          # mu_s particle-shell     [calibration target]
variable ROLLFRIC   index 0.12          # mu_r particle-particle, epsd2 [target]
variable ROLLFRICPW index 0.12          # mu_r particle-shell, epsd2    [target]
variable REST       index 0.50          # restitution             [target, weak]
variable CAPFRIC    index 0.36          # mu_s particle-cover, CO-ROTATING cap mesh [fixed
                                        # protocol input: wheat-acrylic, Sugirbay Table 11]
variable CAPROLL    index 0.29          # mu_r particle-cover [wheat-acrylic, ditto]
variable CAPY       index 0.0135        # frictionless primitive backstop planes [m] — parked
                                        # 1 mm OUTSIDE the cover disks (mesh half-length
                                        # 0.0125), unreachable in normal operation
variable SEED       index 49979687      # insertion seed — the seed-to-seed noise lever
# (particletemplate + distribution seeds are fixed distinct primes below;
#  LIGGGHTS requires all five seeds to be distinct.)
variable TAG        index dev           # output label
variable ROTPER     index 12.0          # drum rotation period [s] = 5 rpm (published protocol;
                                        # Fr = omega^2 R / g ~ 2.1e-3, rolling regime)
variable SETTLET    index 0.8           # settle stage duration [s] (streamed insertion)
variable SPINUP     index 3.0           # discarded spin-up transient [s] — the bed first
                                        # rotates solid-body to the flow angle (~1.2-1.4 s
                                        # at 5 rpm), then needs flow time to steady out.
                                        # 2.2 s sufficed frictionless; the frictional cover
                                        # holds a steeper transient (capped diagnostic:
                                        # -1.8 deg drift at 2.2 s), hence 3.0 s.
variable MEASURE    index 3.2           # steady-state measurement window [s]
variable DUMPDT     index 0.2           # dump frame spacing [s] -> 17 steady frames
variable NPART      index {{ npart }}          # particles = 50% fill: 0.5*pi*R^2*L * (780/1400) / v_mean
variable MESH       index templates/meshes/drum_r0.075_l0.025.stl
variable CMESH      index templates/meshes/drum_caps_r0.075_l0.025.stl
variable YMOD       index {{ ymod }}         # softened Young's modulus [Pa] (numerical device)
variable DT         index {{ dt }}        # timestep [s] (paired with YMOD)
variable GRAVZ      index -1.0          # gravity z sign; -1.0 = normal (fault-injection knob)

# fixed (non-calibrated) material inputs
variable POIS       equal 0.25          # Poisson ratio
variable RHO        equal {{ rho }}          # particle density [kg/m3]

# derived stage durations — floor(x+0.5) not ceil: ceil() turns FP noise in
# the division into off-by-one step counts (0.2/8e-6 -> 25001), which breaks
# the runner's frame-step bookkeeping
variable settlesteps equal floor(v_SETTLET/v_DT+0.5)
variable spinsteps   equal floor(v_SPINUP/v_DT+0.5)
variable meassteps   equal floor(v_MEASURE/v_DT+0.5)
variable dumpevery   equal floor(v_DUMPDT/v_DT+0.5)
variable insevery    equal floor(0.1/v_DT+0.5)

# ---------------------------------------------------------------- setup
atom_style	granular
atom_modify	map array
boundary	m m m
newton		off
communicate	single vel yes
units		si

region		reg block -0.085 0.085 -0.025 0.025 -0.085 0.085 units box
create_box	3 reg

neighbor	0.002 bin
neigh_modify	delay 0

# ---------------------------------------------------------------- material / contact model
fix 	m1 all property/global youngsModulus peratomtype ${YMOD} ${YMOD} ${YMOD}
fix 	m2 all property/global poissonsRatio peratomtype ${POIS} ${POIS} ${POIS}
fix 	m3 all property/global coefficientRestitution peratomtypepair 3 &
		${REST} ${REST} ${REST} &
		${REST} ${REST} ${REST} &
		${REST} ${REST} ${REST}
fix 	m4 all property/global coefficientFriction peratomtypepair 3 &
		${FRIC} ${FRICPW} ${CAPFRIC} &
		${FRICPW} ${FRICPW} ${FRICPW} &
		${CAPFRIC} ${FRICPW} ${FRICPW}
fix 	m5 all property/global coefficientRollingFriction peratomtypepair 3 &
		${ROLLFRIC} ${ROLLFRICPW} ${CAPROLL} &
		${ROLLFRICPW} ${ROLLFRICPW} ${ROLLFRICPW} &
		${CAPROLL} ${ROLLFRICPW} ${ROLLFRICPW}

pair_style gran model hertz tangential history rolling_friction epsd2
pair_coeff	* *

timestep	${DT}

fix		gravi all gravity 9.81 vector 0.0 0.0 ${GRAVZ}

# containment backstop: frictionless-in-effect primitive y-planes parked
# outside the cover disks (type 3 pair would apply, but they are unreachable)
fix ycap1 all wall/gran model hertz tangential history rolling_friction epsd2 primitive type 3 yplane -${CAPY}
fix ycap2 all wall/gran model hertz tangential history rolling_friction epsd2 primitive type 3 yplane +${CAPY}

# drum shell (type 2, FRICPW) + co-rotating end covers (type 3, CAPFRIC):
# two meshes, one wall fix, both rotated in stage 2
fix drum all mesh/surface file ${MESH} type 2
fix caps all mesh/surface file ${CMESH} type 3
fix drumwall all wall/gran model hertz tangential history rolling_friction epsd2 mesh n_meshes 2 meshes drum caps

# ---------------------------------------------------------------- particles (fixed PSD)
# discrete distribution: d = 3.4 / 3.7 / 4.0 mm, mass weights 0.25 / 0.50 / 0.25
{{ psd_block }}

# streamed insertion into the drum interior: the 50% fill puts ~37% solids in
# the insertion region — too dense for a single insert/pack shot, so top up
# every 0.1 s through the settle stage as inserted particles rain down.
# The region must COVER every physically reachable particle center (radial
# 0.0735 > 0.075 - r_min = 0.0733; |y| 0.011 > 0.0125 - r_min = 0.0108),
# otherwise settled wall-adjacent particles escape the particles_in_region
# count and the fix over-inserts (first smoke run: 6337 atoms vs 4600).
# all_in yes keeps inserted spheres inside the region, clear of the shell.
region	bc cylinder y 0. 0. 0.0735 -0.011 0.011 units box
fix	ins all insert/pack seed ${SEED} distributiontemplate pdd1 vel constant 0. -0. -0.3 &
		insert_every ${insevery} overlapcheck yes all_in yes particles_in_region ${NPART} region bc

fix	integr all nve/sphere

# timestep sanity (Phase-3 exit-criterion check)
fix	ts all check/timestep/gran 2000 0.1 0.1

# ---------------------------------------------------------------- output
compute	rke all erotate/sphere
thermo_style	custom step atoms ke c_rke f_ts[1] f_ts[2]
thermo		2000
thermo_modify	lost ignore norm no
dump	dmp all custom ${dumpevery} post/${TAG}_*.liggghts id type x y z vx vy vz omegax omegay omegaz radius
dump	dmpstl all mesh/stl ${dumpevery} post/${TAG}_mesh_*.stl

# ---------------------------------------------------------------- stages
# stage 1 — stream in particles and settle to a half-full bed
run	${settlesteps}
unfix	ins
variable natoms equal atoms
variable ke_settle equal ke
print	"AUDIT settle: step ${settlesteps}  atoms = ${natoms} (target ${NPART})  KE = ${ke_settle} J"

# stage 2 — rotate shell AND covers about y at 5 rpm; discard the transient.
# Sign convention: positive period -> angular velocity +y; the bed climbs the
# -x side, so the steady surface has dz/dx < 0 (the measurement asserts this).
fix	rot all move/mesh mesh drum rotate origin 0. 0. 0. axis 0. 1. 0. period ${ROTPER}
fix	rotc all move/mesh mesh caps rotate origin 0. 0. 0. axis 0. 1. 0. period ${ROTPER}
run	${spinsteps}

# stage 3 — steady-state window: frames every DUMPDT for the multi-frame fit
run	${meassteps}
variable ke_meas equal ke
print	"AUDIT measure-end: KE = ${ke_meas} J (continuous rolling -> nonzero, no spikes)"

# final state marker (runner/render convention; same content as the last frame)
write_dump all custom post/${TAG}_final.liggghts id type x y z vx vy vz omegax omegay omegaz radius
